%:TDka+.lfOb-hl"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="YYs;s7QjpW,cwqS=wh7v"><field name="TEXT">Instructions: Use the arrow keys/joystick to move, and avoid comets! You can shoot fireballs at projectiles/enemies by using the 'A' button on the console, or the 'Z' button on a keyboard.</field></shadow></value><next><block type="set_current_tilemap" id=";[8#vNF3ejS|apTg/,]="><value name="tilemap"><shadow type="tiles_tilemap_editor" id="rKog2S%%F}9Ixqr8|mNr"><field name="tilemap">tilemap`level14`</field><data>{"commentRefs":[],"fieldData":{"tilemap":"level14"}}</data></shadow></value><next><block type="game_show_long_text" id="j6[1Iy*7uG?+[O_Y(Pb,"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="CyZY`N#%D%LgkO-+!MA+"><field name="TEXT">For Level 1: Move to the right, avoiding comets until you find the castle. Go through the doors!</field></shadow></value><next><block type="set_current_tilemap" id="2)|+C1Z[|ZRQjyo;trp="><value name="tilemap"><shadow type="tiles_tilemap_editor" id="mns)l,L_6-5(Z^_%;kgl"><field name="tilemap">tilemap`level15`</field><data>{"commentRefs":[],"fieldData":{"tilemap":"level15"}}</data></shadow></value><next><block type="game_show_long_text" id="LPkpI7hgsr02nt|*}YH="><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="FEB?|5^J)M)#6aR(*et8"><field name="TEXT">For Level 2: Go through the maze, and find the hidden gold block. Be careful, you only have 70 seconds!</field></shadow></value><next><block type="set_current_tilemap" id="|.;?emEED0Y=oQ5r8Sr2"><value name="tilemap"><shadow type="tiles_tilemap_editor" id="?YZC2ea(#|Xtq.vE!c|S"><field name="tilemap">tilemap`level16`</field><data>{"commentRefs":[],"fieldData":{"tilemap":"level16"}}</data></shadow></value><next><block type="game_show_long_text" id="8H$=^jOfWUK(O$@Z5:d0"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="1Nx]Ak